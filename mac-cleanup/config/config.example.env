# MacScrub — пример постоянных настроек.
# Скопируйте в:  ~/Library/Application Support/MacScrub/config.env
# Значения задают параметры по умолчанию; флаги командной строки их перекрывают.

# Период по умолчанию: this-day | this-week | this-month | all
WINDOW=this-week

# Категории через запятую (см. `macscrub categories`).
# Пусто = безопасный набор по умолчанию. Можно указать all-safe или all.
CATEGORIES=user-caches,user-logs,diagnostic-reports,trash,quicklook-thumbnails,temp-folders

# Способ удаления: trash (в Корзину, безопасно) | delete (безвозвратно)
METHOD=trash

# Трогать системные пути (нужен sudo): 0 | 1
INCLUDE_SYSTEM=0
